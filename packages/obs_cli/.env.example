# Copy this file to `.env` in your current working directory (or export the
# values in your shell) so the OBS CLI can authenticate against your OBS
# Studio instance.
#
# The CLI reads these via `ObsWebSocket.connectFromEnv()` and will
# automatically connect when OBS_WEBSOCKET_URL is set.
#
# Priority order:
#   1. System environment variables (export OBS_WEBSOCKET_URL=...)
#   2. .env file in current working directory
#   3. Compile-time defaults (from obs_websocket package)

# Full URL of the OBS WebSocket server. `ws://host:port` or `wss://host:port`.
OBS_WEBSOCKET_URL=ws://localhost:4455

# Password configured in OBS Studio → Tools → WebSocket Server Settings.
# Leave unset/blank for anonymous (auth-disabled) servers.
OBS_WEBSOCKET_PASSWORD=

# Connect timeout in seconds. Optional; defaults to 120.
OBS_WEBSOCKET_TIMEOUT=120
