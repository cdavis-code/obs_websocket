# Copy this file to `.env` and fill in your OBS WebSocket credentials.
#
# This file is used by ObsWebSocket.connectFromEnv() to automatically
# connect at startup when OBS_WEBSOCKET_URL is set.
#
# Usage:
# ```dart
# final obs = await ObsWebSocket.connectFromEnv();
# ```

# Required: OBS WebSocket server URL (ws:// or wss://)
OBS_WEBSOCKET_URL=ws://localhost:4455

# Optional: OBS WebSocket password (if authentication is enabled in OBS)
OBS_WEBSOCKET_PASSWORD=

# Optional: Connection timeout in seconds (default: 120)
OBS_WEBSOCKET_TIMEOUT=120
